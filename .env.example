# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cloud MySQL database configuration details.
# You can retrieve these values directly from your cloud database console:
# e.g., Host, Port, User, Password, Database Name.
DB_HOST=""
DB_PORT="24921"
DB_USER="avnadmin"
DB_PASSWORD=""
DB_NAME="defaultdb"

# SSL Setting for Cloud MySQL. 
# Many cloud databases require SSL to connect by default. Set this value to "true" to enforce SSL connection.
DB_SSL_REQUIRED="true"

# Resend API Key for sending lead email notifications directly to user's mailbox.
# Obtain your key from https://resend.com
RESEND_API_KEY=""
